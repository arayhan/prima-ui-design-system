{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["react", "react-dom", "vite/client"],
    "paths": {
      "arayhan-design-system/styles.css": ["../src/styles.css"],
      "arayhan-design-system": ["../src/index.ts"]
    }
  },
  "include": ["src"]
}
